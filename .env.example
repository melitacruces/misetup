# ==========================================
# VARIABLES DE ENTORNO PARA DESPLIEGUE
# Copia este archivo a ".env.local" y rellena los valores.
# ==========================================

# 1. Base de datos Neon PostgreSQL
# Ve al panel de control de Neon (https://neon.tech) para obtener estos strings.
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[ENDPOINT].neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://[USER]:[PASSWORD]@[ENDPOINT].neon.tech/neondb?sslmode=require"

# 2. Seguridad
# Clave maestra para acceder al "Editor Mode" en la interfaz.
EDITOR_PASSWORD="pon_aqui_una_clave_segura_para_edicion_en_produccion"
