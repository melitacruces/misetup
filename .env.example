# ==========================================
# VARIABLES DE ENTORNO PARA DESPLIEGUE
# Copia este archivo a ".env.local" y rellena los valores.
# ==========================================

# 1. Modo de la aplicación.
# preview: sandbox público; nunca escribe en PostgreSQL (valor recomendado para Vercel).
# database: instalación propia con persistencia en TU base de datos.
MISETUP_MODE="preview"

# 2. Base de datos PostgreSQL / Neon.
# En preview usa una credencial SELECT-only. En database usa la base de datos de tu instalación.
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[ENDPOINT]-pooler.neon.tech/neondb?sslmode=require"

# También se aceptan POSTGRES_URL y POSTGRES_URL_NON_POOLING para mantener
# compatibilidad con instalaciones anteriores que usen variables POSTGRES_URL.

# 3. Solo para MISETUP_MODE="database".
# Protege los cambios persistentes de tu instalación.
EDITOR_PASSWORD="cambia_esto_por_una_clave_larga_y_unica"
